COMPOSE_PROJECT_NAME=satellite-image-service

# Пути проекта
HOST_DATA_DIR=./data
HOST_LAND_MASK_DIR=./data/land-mask/ne_10m_land
HOST_POSTGRES_INIT_DIR=./services/postgres-init
HOST_SPARK_APP_DIR=./services/spark/app
HOST_SPARK_MODELS_DIR=./services/spark/models
HOST_WEB_APP_DIR=./services/web/app
SPARK_APP_DIR=/app
SPARK_MODELS_DIR=/app/models
WEB_APP_DIR=/app

# PostgreSQL
POSTGRES_IMAGE=postgres:16
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_HOST_PORT=5432
POSTGRES_USER=satellite
POSTGRES_PASSWORD=satellite
POSTGRES_DB=satellite

# MinIO
MINIO_IMAGE=minio/minio:RELEASE.2025-09-07T16-13-09Z-cpuv1
MINIO_ENDPOINT=http://minio:9000
MINIO_PUBLIC_ENDPOINT=http://localhost:9000
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=satellite-images
MINIO_PRESIGNED_TTL_SECONDS=86400

# Kafka и Zookeeper
ZOOKEEPER_IMAGE=confluentinc/cp-zookeeper:7.5.0
ZOOKEEPER_CLIENT_PORT=2181
ZOOKEEPER_TICK_TIME=2000
KAFKA_IMAGE=confluentinc/cp-kafka:7.5.0
KAFKA_BROKER_ID=1
KAFKA_HOST_PORT=9092
KAFKA_EXTERNAL_PORT=29092
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC=raw-images
KAFKA_CONSUMER_GROUP=spark-processor
KAFKA_ZOOKEEPER_CONNECT=zookeeper:2181
KAFKA_ADVERTISED_LISTENERS=PLAINTEXT://kafka:9092,PLAINTEXT_HOST://localhost:29092
KAFKA_LISTENER_SECURITY_PROTOCOL_MAP=PLAINTEXT:PLAINTEXT,PLAINTEXT_HOST:PLAINTEXT
KAFKA_LISTENERS=PLAINTEXT://0.0.0.0:9092,PLAINTEXT_HOST://0.0.0.0:29092
KAFKA_OFFSETS_TOPIC_REPLICATION_FACTOR=1
KAFKA_AUTO_CREATE_TOPICS_ENABLE=true

# Producer
PRODUCER_LOCAL_INPUT_DIR=/data
CHECK_INTERVAL=2
REMOVE_AFTER_UPLOAD=true

# Префиксы объектов в MinIO
RAW_PREFIX=raw/
PROCESSED_PREFIX=processed/
TILE_PREFIX=processed/tiles/
MASK_PREFIX=processed/masks/
SHAPEFILE_PREFIX=processed/shapefiles/
STATUS_PREFIX=processed/status/

# Web
WEB_HOST_PORT=8080
WEB_CONTAINER_PORT=8000
WEB_CONCURRENCY=2
DOWNLOAD_DIR=/data
EE_PROJECT=
TILE_RENDER_PADDING_RATIO=0.0
HTTP_CACHE_SECONDS=86400
MASK_ALPHA_MULTIPLIER=0.72

# Spark
SPARK_NO_DAEMONIZE=true
SPARK_MASTER_HOST=spark-master
SPARK_MASTER_URL=spark://spark-master:7077
SPARK_MASTER_PORT=7077
SPARK_MASTER_UI_INTERNAL_PORT=8080
SPARK_MASTER_UI_PORT=8085
SPARK_WORKER_UI_INTERNAL_PORT=8081
SPARK_WORKER_1_UI_PORT=8086
SPARK_WORKER_2_UI_PORT=8087
SPARK_WORKER_3_UI_PORT=8088
SPARK_WORKER_CORES=2
SPARK_WORKER_MEMORY=6g
SPARK_DAEMON_MEMORY=1g
SPARK_DRIVER_MEMORY=2g
SPARK_EXECUTOR_MEMORY=5g
SPARK_EXECUTOR_MEMORY_OVERHEAD=1g
SPARK_EXECUTOR_CORES=2
SPARK_TASK_CPUS=2
SPARK_DEFAULT_PARALLELISM=3
SPARK_SHM_SIZE=2g
SPARK_GPUS=all

# Обработка снимков
SPARK_LOCAL_INPUT_DIR=/data/input
WORK_DIR=/tmp/satellite-processing
MODEL_PATH=/app/models/UnetPP.pth
LAND_MASK_CONTAINER_DIR=/opt/land-mask
LAND_MASK_PATH=/opt/land-mask/ne_10m_land.shp
SEGMENTATION_DEVICE=cuda
NVIDIA_VISIBLE_DEVICES=all
NVIDIA_DRIVER_CAPABILITIES=compute,utility
PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True
POLL_INTERVAL=5
PROCESSOR_WORKERS=3
TILE_SIZE=1000
TILE_MIN_VALID_RATIO=0.08
MASK_FILLED_THRESHOLD=0.05
MASK_MIN_AREA=0.00001
MASK_MERGE_GAPS=false
MASK_GAP_BUFFER=0.0
